        { "key": "address", "label": "주소 (도로명)", "type": "text", "required": true },
        { "key": "email", "label": "이메일", "type": "email", "required": false },
        { "key": "kakao_channel", "label": "카카오톡 채널", "type": "text", "required": false, "example": "@my-clinic" },
        { "key": "booking_url", "label": "외부 예약 URL", "type": "url", "required": false }
