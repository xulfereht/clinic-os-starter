{
  "$comment": "SOT for onboarding features. Read by AI agents to guide clinic setup.",
  "version": "2.0.0",
  "description": "Clinic-OS 온보딩 기능 레지스트리. 에이전트가 이 파일을 읽고 클라이언트의 셋업을 안내합니다. 핵심부터 차근차근 접근.",
  "usage": {
    "template": ".agent/onboarding-registry.json (코어 배포, 읽기 전용)",
    "state": ".agent/onboarding-state.json (클라이언트별 진행 상태, setup 시 생성)"
  },
  "tiers": {
    "1": {
      "name": "배포 필수",
      "description": "사이트가 정상 작동하고 법적 요건을 충족하는 최소한의 설정. 이것만 되어도 사이트는 뜬다.",
      "goal": "사이트가 돌아가고 법적 문제가 없는 상태 → 1차 배포 가능",
      "eta": "1-2일",
      "flow_description": "보안 → 병원 정보 → 연락처 → 진료시간 → 브랜딩 → 약관"
    },
    "2": {
      "name": "핵심 콘텐츠",
      "description": "사이트가 '비어있지 않게' 보이도록 하는 필수 콘텐츠. 실제 운영 중인 병원처럼 보이기 위한 요소.",
      "goal": "홈페이지 방문자가 '실제 병원'이라고 인식할 수 있는 상태 → 2차 배포",
      "eta": "3-5일",
      "flow_description": "콘텐츠 임포트 → 의료진 → 프로그램 → 홈페이지 구성 → 오시는길 → SNS 썸네일"
    },
    "3": {
      "name": "환자 연결",
      "description": "온라인으로 환자가 접수되고 예약될 수 있는 기능. 실제 업무가 시작되는 단계.",
      "goal": "환자가 온라인으로 문진 작성 → 예약 → 확인 문자 받는 플로우 완성",
      "eta": "1주차",
      "flow_description": "문진표 → 예약 시스템 → 알림 채널 → 블로그 → 샘플데이터 정리"
    },
    "4": {
      "name": "성장 & 마케팅",
      "description": "운영이 안정된 후 환자 유치와 재방문을 위한 마케팅 기능. 병원별 선택적 활성화.",
      "goal": "문자 캠페인, SEO, 후기 관리로 환자 유입 확대",
      "eta": "2-4주차",
      "flow_description": "문자 캠페인 → 상담 관리 → 후기 수집 → 검색최적화 → 다국어 → 검사도구/고급스킨"
    },
    "5": {
      "name": "운영 고도화",
      "description": "내부 업무 효율화와 고급 기능. 재고, 회계, 외부 연동 등 필요할 때만 선택적으로.",
      "goal": "병원별 맞춤 자동화와 고급 기능",
      "eta": "필요시",
      "flow_description": "기존 데이터 마이그레이션 → 재고/회계 → AI 설정 → 외부 연동 → API 관리"
    }
  },
  "categories": [
    "essential",
    "content",
    "patient-service",
    "marketing",
    "operations",
    "advanced"
  ],
  "flows": {
    "onboarding": {
      "description": "Full clinic setup from zero to production",
      "tiers": [1, 2, 3, 4, 5],
      "decision_points": [
        {
          "after_tier": 1,
          "question": "1차 배포를 진행하시겠습니까?",
          "yes_action": "deploy to production",
          "no_action": "continue to tier 2"
        },
        {
          "after_tier": 3,
          "question": "온라인 예약/문진이 활성화됩니다. 배포하시겠습니까?",
          "yes_action": "deploy patient services",
          "no_action": "continue to tier 4-5"
        }
      ]
    },
    "quick_start": {
      "description": "Minimum viable clinic site",
      "features": ["admin-account", "clinic-info", "clinic-contact", "clinic-hours", "branding-minimal", "terms-management"],
      "time_estimate": "2-4 hours"
    },
    "patient_ready": {
      "description": "Ready for online patient intake",
      "extends": "quick_start",
      "additional_features": ["intake-setup", "reservation-setup", "notifications", "blog-management"],
      "time_estimate": "1 week"
    }
  },
