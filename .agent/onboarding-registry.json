{
  "$comment": "SOT for onboarding features. Read by AI agents to guide clinic setup.",
  "version": "1.0.0",
  "description": "Clinic-OS 온보딩 기능 레지스트리. 에이전트가 이 파일을 읽고 클라이언트의 셋업을 안내합니다.",
  "usage": {
    "template": ".agent/onboarding-registry.json (코어 배포, 읽기 전용)",
    "state": ".agent/onboarding-state.json (클라이언트별 진행 상태, setup 시 생성)"
  },
  "tiers": {
    "1": {
      "name": "배포 필수",
      "description": "이것 없이는 사이트가 정상 작동하지 않음. 최우선 완료 후 1차 배포.",
      "goal": "사이트가 돌아가고 법적 요건을 충족하는 상태"
    },
    "2": {
      "name": "핵심 콘텐츠",
      "description": "사이트가 비어보이지 않게. 의료진, 프로그램, 홈페이지 구성.",
      "goal": "환자가 봤을 때 실제 운영 중인 병원처럼 보이는 상태"
    },
    "3": {
      "name": "환자 서비스",
      "description": "환자 유입과 접수가 가능한 상태. 접수 폼, 예약, 기본 콘텐츠.",
      "goal": "환자가 온라인으로 접수하고 예약할 수 있는 상태"
    },
    "4": {
      "name": "마케팅 & 확장",
      "description": "환자 유치와 재방문을 위한 마케팅 도구. 운영 안정 후 세팅.",
      "goal": "SMS 캠페인, SEO, 다국어 등으로 환자 유입 확대"
    },
    "5": {
      "name": "운영 고도화",
      "description": "내부 업무 효율화와 고급 기능. 필요한 것만 선택적 활성화.",
      "goal": "재고, 지출, AI, 외부 연동 등 병원별 맞춤 기능"
    }
  },
  "categories": [
    "essential",
    "content",
    "patient-service",
    "marketing",
    "operations",
    "system",
    "advanced"
  ],
  "features": [

    {
      "id": "admin-account",
      "name": "관리자 계정 보안",
      "description": "시드 기본 비밀번호(admin123)를 변경하고 관리자 이메일을 등록. 변경하지 않으면 누구나 관리자 접근 가능.",
      "tier": 1,
      "category": "essential",
      "requires_human": true,
      "human_inputs": [
        { "key": "password", "label": "관리자 비밀번호", "type": "password", "required": true },
        { "key": "email", "label": "관리자 이메일", "type": "email", "required": true }
      ],
      "admin_path": "/admin/change-password",
      "doc_ref": "CLINIC_INFO_SETUP.md#4-관리자-계정-보안",
      "depends_on": [],
      "db_tables": ["super_admins"],
      "source_paths": ["src/pages/admin/change-password.astro", "src/pages/api/auth/change-password.ts", "src/lib/password-hasher.ts"],
      "setup_notes": "시드 기본값 admin123에서 반드시 변경. 최소 8자, 영문+숫자+특수문자 권장."
    },

    {
      "id": "clinic-info",
      "name": "병원 기본 정보",
      "description": "/admin/settings에서 병원 이름(한/영), 소개, 대표자, 사업자번호, URL 입력. 홈페이지 헤더·푸터·메타태그에 자동 반영.",
      "tier": 1,
      "category": "essential",
      "requires_human": true,
      "human_inputs": [
        { "key": "name", "label": "병원 이름 (한글)", "type": "text", "required": true, "example": "서울한의원" },
        { "key": "english_name", "label": "병원 이름 (영문)", "type": "text", "required": true, "example": "Seoul Korean Medicine Clinic" },
        { "key": "description", "label": "병원 한 줄 소개", "type": "text", "required": true },
        { "key": "representative_name", "label": "대표자 이름", "type": "text", "required": true },
        { "key": "business_license_number", "label": "사업자등록번호", "type": "text", "required": true, "example": "123-45-67890" },
        { "key": "url", "label": "웹사이트 URL", "type": "url", "required": true, "example": "https://my-clinic.com" }
      ],
      "admin_path": "/admin/settings",
      "doc_ref": "CLINIC_INFO_SETUP.md#기본-정보",
      "depends_on": ["admin-account"],
      "db_tables": ["clinics", "site_settings"],
      "source_paths": ["src/pages/admin/settings/index.astro", "src/pages/api/admin/clinic-info.ts", "src/lib/clinic.ts"]
    },

    {
