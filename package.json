{
  "name": "clinic-os-client",
  "version": "1.34.7",
  "type": "module",
  "description": "Clinic-OS 클라이언트",
  "scripts": {
    "setup": "node scripts/setup-clinic.js",
    "setup:fast": "node scripts/setup-clinic.js --parallel-install",
    "setup:step": "node scripts/setup-step.js",
    "setup:status": "node scripts/setup-step.js --status",
    "setup:reset": "node scripts/setup-step.js --reset",
    "setup:agent": "node scripts/setup-agent.js",
    "agent:context": "node scripts/generate-agent-context.js",
    "agent:doctor": "node scripts/agent-doctor.js",
    "agent:sync": "node scripts/agent-doctor.js --sync",
    "agent:report-issue": "node scripts/agent-report-issue.js",
    "agent:lifecycle": "node scripts/agent-lifecycle.js",
    "agent:snapshot": "node scripts/agent-snapshot.js",
    "agent:restore": "node scripts/agent-restore.js",
    "status": "node scripts/status.js",
    "health": "node scripts/health-audit.js",
    "health:fix": "node scripts/health-audit.js --fix",
    "handoff:claim": "node scripts/handoff-claim.js",
    "error:status": "node scripts/lib/error-recovery.mjs status",
    "error:recover": "node scripts/lib/error-recovery.mjs recover",
    "error:resolve": "node scripts/lib/error-recovery.mjs resolve",
    "update:starter": "node scripts/update-starter.js",
    "update:starter-core": "node scripts/update-starter-core.js",
    "core:pull": "node .docking/engine/fetch.js",
    "core:pull:beta": "node .docking/engine/fetch.js --beta",
    "core:pull:stable": "node .docking/engine/fetch.js --stable",
    "core:repair": "node scripts/core-repair.js",
    "fetch": "node .docking/engine/fetch.js",
    "dev": "node scripts/dev-preflight.js && npm run dev --prefix core",
    "build": "npm run build --prefix core",
    "deploy": "node scripts/deploy-guard.js",
    "doctor": "node scripts/doctor.js",
    "db:init": "node .docking/engine/migrate.js",
    "db:seed": "node scripts/seed-local.js",
    "db:migrate": "node .docking/engine/migrate.js",
    "db:pull": "node scripts/db-sync.js",
    "plugin:create": "node scripts/plugin-create.js",
    "skin:create": "node scripts/skin-create.js",
    "skin:check": "node scripts/skin-check.js",
    "skin:bundle": "node scripts/skin-bundle.js",
    "skin:install": "node scripts/skin-install.js",
    "skin:remove": "node scripts/skin-remove.js",
    "skin:submit": "node scripts/skin-submit.js",
    "skin:test:hq-local": "node scripts/test-skin-marketplace-local.js",
    "skin:test:hq-remote": "node scripts/test-skin-marketplace-remote.js",
    "survey-tool:create": "node scripts/survey-tool-create.js",
    "survey-tool:check": "node scripts/survey-tool-check.js",
    "survey-tool:install": "node scripts/survey-tool-install.js",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:seed": "node scripts/e2e-admin-seed.js",
    "test:e2e": "npm run db:init && npm run db:seed && npm run test:e2e:seed && playwright test",
    "test:e2e:headed": "npm run db:init && npm run db:seed && npm run test:e2e:seed && playwright test --headed"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "fs-extra": "^11.2.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "wrangler": "^4.61.1"
  }
}